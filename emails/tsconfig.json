{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNEXT",
    "moduleResolution": "bundler",
    "noUncheckedSideEffectImports": false,
    "noImplicitReturns": true,
    "allowImportingTsExtensions": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "paths": {
      "@monetr/emails/*": ["./src/*"]
    }
  }
}

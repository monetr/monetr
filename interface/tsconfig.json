{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNEXT",
    "moduleResolution": "bundler",
    "noUncheckedSideEffectImports": false,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "outDir": "../server/ui/static",
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": true,
    // monetr's model classes hydrate through Object.assign(this, Partial<T>), which strictPropertyInitialization
    // cannot see, so we leave just this one strict check off instead of asserting every model field with `!:`.
    "strictPropertyInitialization": false,
    "target": "ES2022",
    "types": ["node", "@rstest/core/globals", "@testing-library/jest-dom"],
    "paths": {
      "@monetr/interface/*": ["./src/*"]
    }
  },
  "include": ["src/setupTests.ts", "src/**/*"]
}
